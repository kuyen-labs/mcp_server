# Copy to .env and adjust. Loaded automatically by src/config/env.ts (dotenv)
# from the process current working directory (e.g. repo root when running locally).
# Claude Code plugin users set FUUL_API_BASE_URL in the plugin userConfig instead.

# FUUL_API_BASE_URL=https://api.fuul.xyz
# FUUL_OAUTH_CLIENT_ID=fuul-agent
# FUUL_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/callback
# FUUL_MCP_DEBUG=1
# FUUL_MCP_TOOL_TIMEOUT_MS=90000
